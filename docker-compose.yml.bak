services:
  postgres:
    image: pgvector/pgvector:pg16
    restart: unless-stopped
    secrets:
      - postgres_password
    environment:
      POSTGRES_DB: ${POSTGRES_DB}
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    ports:
      - "5433:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - n8n_internal

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    networks:
      - n8n_internal
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      retries: 5

  n8n:
    build:
      context: .
      dockerfile: Dockerfile.n8n
    ports:
      - "5678:5678"
    env_file:
      - .env
    restart: unless-stopped
    depends_on:
      - postgres
      - redis
    secrets:
      - n8n_encryption_key

    environment:
      NODE_ENV: production
      GENERIC_TIMEZONE: Africa/Johannesburg

      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD: ${POSTGRES_PASSWORD}

      EXECUTIONS_MODE: queue
      QUEUE_BULL_REDIS_HOST: redis
      QUEUE_BULL_REDIS_PORT: 6379
      QUEUE_BULL_PREFIX: n8n
      OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS: "true"

      N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
      N8N_DIAGNOSTICS_ENABLED: "false"
      N8N_VERSION_NOTIFICATIONS_ENABLED: "false"
      N8N_COMMUNITY_PACKAGES_ENABLED: "true"
      N8N_CUSTOM_EXTENSIONS: /home/node/.n8n
      N8N_ENCRYPTION_KEY_FILE: /run/secrets/n8n_encryption_key
      
      EXECUTIONS_DATA_SAVE_ON_SUCCESS: none
      EXECUTIONS_DATA_SAVE_ON_ERROR: all

      N8N_LISTEN_ADDRESS: 0.0.0.0
      N8N_HOST: oldskooln8n.xyz
      N8N_WEBHOOK_URL: https://oldskooln8n.xyz
      N8N_EDITOR_BASE_URL: https://oldskooln8n.xyz

      N8N_TRUST_PROXY: "true"
      
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:5678"]
      interval: 30s
      timeout: 5s
      retries: 3
      
    volumes:
      - n8n_data:/home/node/.n8n
      - "/home/ianw/storage/source:/source"
      - "/home/ianw/storage/destination:/destination"

    networks:
      - n8n_internal
  python-fx:
    build: ./python-fx
    working_dir: /app
    command: gunicorn -w 2 -b 0.0.0.0:5000 app:app
    volumes:
      - ./python-fx:/app
    ports:
      - "5000:5000"
    networks:
      - n8n_internal
    restart: unless-stopped
    secrets:
      - postgres_password
    environment:
      - DB_HOST=postgres
      - DB_NAME=${POSTGRES_DB}
      - DB_USER=${POSTGRES_USER}
      - DB_PASSWORD_FILE=/run/secrets/postgres_password

  n8n-worker:
    build:
      context: .
      dockerfile: Dockerfile.n8n
    restart: unless-stopped
    depends_on:
      - postgres
      - redis
    command: worker
    secrets:
      - n8n_encryption_key
    environment:
      NODE_ENV: production
      GENERIC_TIMEZONE: Africa/Johannesburg

      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD: ${POSTGRES_PASSWORD}
      
      N8N_COMMUNITY_PACKAGES_ENABLED: "true"
      N8N_CUSTOM_EXTENSIONS: /home/node/.n8n
      N8N_ENCRYPTION_KEY_FILE: /run/secrets/n8n_encryption_key

      EXECUTIONS_MODE: queue
      QUEUE_BULL_REDIS_HOST: redis
      QUEUE_BULL_REDIS_PORT: 6379
      QUEUE_BULL_PREFIX: n8n

    volumes:
      - n8n_data:/home/node/.n8n
    networks:
      - n8n_internal
      
  cloudflared:
    image: cloudflare/cloudflared:2024.12.0
    restart: unless-stopped
    command: tunnel run oldskooln8n
    volumes:
      - ./cloudflared:/etc/cloudflared
    networks:
      - n8n_internal
  doc-engine:
    build: ./doc-engine
    container_name: doc-engine
    restart: unless-stopped
    depends_on:
      - postgres
    secrets:
      - postgres_password
      - google_service_account
    environment:
      DB_HOST: postgres
      DB_NAME: ${POSTGRES_DB}
      DB_USER: ${POSTGRES_USER}
      DB_PASSWORD_FILE: /run/secrets/postgres_password
      GOOGLE_SERVICE_ACCOUNT_FILE: /run/secrets/google_service_account
    volumes:
      - ./doc-engine:/app
    networks:
      - n8n_internal
    ports:
      - "8000:8000"

  chat-backend:
    build: ./chat-backend
    container_name: n8n-lab-chat-backend
    restart: unless-stopped
    secrets:
    - postgres_password
    depends_on:
      - n8n
      - postgres
    networks:
      - n8n_internal
    ports:
      - "8001:8000"
    volumes:
      - ./chat-backend:/app
    environment:
      DB_HOST: postgres
      DB_NAME: ${POSTGRES_DB}
      DB_USER: ${POSTGRES_USER}
      DB_PASSWORD: /run/secrets/postgres_password
  crm-backend:
    build: ./crm-backend
    ports:
      - "8002:8002"
    secrets:
      - postgres_password
    environment:
      DB_HOST: postgres
      DB_NAME: crm
      DB_USER: ${POSTGRES_USER}
      DB_PASSWORD_FILE: /run/secrets/postgres_password
      UPLOAD_FOLDER: /data/crm_documents
    volumes:
      - ./crm-backend:/app
      - crm_documents:/data/crm_documents
    networks:
      - n8n_internal
    depends_on:
      - postgres

  crm-doc-engine:
    build:
      context: ./crm-doc-engine
    ports:
      - "8003:8003"
    networks:
      - n8n_internal
    depends_on:
      - ollama

  ollama:
    image: ollama/ollama
    container_name: ollama
    ports:
      - "11434:11434"
    volumes:
      - /home/ianw/ollama-models:/root/.ollama
    environment:
      - OLLAMA_NUM_PARALLEL=4
      - OLLAMA_MAX_LOADED_MODELS=2
      - OLLAMA_KEEP_ALIVE=5m
    networks:
      - n8n_internal
    restart: unless-stopped    
  recovery-api:
    build: 
      context: .
      dockerfile: recovery/api/Dockerfile
    container_name: recovery-api
    restart: unless-stopped
    ports:
      - "5050:5050"
    volumes:
      - ./scripts:/app/scripts
      - /mnt/d/backups:/mnt/d/backups
    environment:
      - TZ=Africa/Johannesburg
      
networks:
  n8n_internal:
    driver: bridge

volumes:
  n8n_data:
  postgres_data:
  redis_data:
  crm_documents:


secrets:
  postgres_password:
    file: /home/ianw/docker/secrets/postgres_password

  n8n_encryption_key:
    file: /home/ianw/docker/secrets/n8n_encryption_key

  google_service_account:
    file: /home/ianw/docker/secrets/service-account.json